{
  "name": "@ohif/mode-lung-ct-compare",
  "version": "3.13.0-beta.71",
  "description": "Lung nodule CT registration compare (dual stack + 3D)",
  "author": "OHIF Contributors",
  "license": "MIT",
  "main": "dist/ohif-mode-lung-ct-compare.umd.js",
  "module": "src/index.tsx",
  "files": [
    "dist/**",
    "README.md"
  ],
  "repository": "OHIF/Viewers",
  "keywords": [
    "ohif-mode"
  ],
  "engines": {
    "node": ">=14",
    "npm": ">=6",
    "yarn": ">=1.16.0"
  },
  "peerDependencies": {
    "i18next": "17.3.1",
    "@ohif/core": "3.13.0-beta.71",
    "@ohif/extension-cornerstone": "3.13.0-beta.71",
    "@ohif/extension-default": "3.13.0-beta.71",
    "@ohif/extension-cornerstone-dicom-seg": "3.13.0-beta.71",
    "@ohif/extension-dicom-video": "3.13.0-beta.71",
    "@ohif/extension-lung-ct-compare": "3.13.0-beta.71"
  },
  "dependencies": {
    "@babel/runtime": "7.28.2",
    "immutability-helper": "3.1.1"
  },
  "devDependencies": {
    "webpack": "5.105.0",
    "webpack-merge": "5.10.0"
  },
  "scripts": {
    "clean": "shx rm -rf dist",
    "clean:deep": "yarn run clean && shx rm -rf node_modules",
    "dev": "cross-env NODE_ENV=development webpack --config .webpack/webpack.dev.js --watch --output-pathinfo",
    "dev:cornerstone": "yarn run dev",
    "build": "cross-env NODE_ENV=production webpack --config .webpack/webpack.prod.js",
    "build:package": "yarn run build",
    "start": "yarn run dev",
    "test:unit": "jest --watchAll",
    "test:unit:ci": "jest --ci --runInBand --collectCoverage --passWithNoTests"
  }
}
